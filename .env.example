NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173

DATABASE_URL=postgresql://devpilot:devpilot@localhost:5432/devpilotdb
REDIS_URL=redis://localhost:6379

# GitHub App / OAuth
GITHUB_APP_ID=
# Prefer file path in production; if inline, keep \n escaped
GITHUB_PRIVATE_KEY_PATH=
GITHUB_PRIVATE_KEY=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=

# Auth/session
JWT_SECRET=
JWT_ISSUER=devpilot

# AI
ENABLE_OPENAI=true
OPENAI_API_KEY=
AI_MODE=live
AI_MODEL=gpt-4.1-mini
OPENAI_COST_CENTS_PER_1K_TOKENS=0

# Observability
SENTRY_DSN=

# Queue/socket/rate limit
QUEUE_NAME=pr-jobs
SOCKET_REDIS_HOST=localhost
SOCKET_REDIS_PORT=6379
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=120
